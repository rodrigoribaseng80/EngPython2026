    "import ipywidgets as widgets\n",
    "from IPython.display import display\n",
    "\n",
    "def resolver_circuito(v_fonte, v_extra, r1, r2, r3, r4):\n",
    "    \"\"\"\n",
    "    Resolve o circuito do Sadiku usando análise nodal.\n",
    "    v_fonte: Fonte de 14V\n",
    "    v_extra: Fonte de 6V (entre os nós)\n",
    "    r1: 4 ohms | r2: 3 ohms | r3: 2 ohms | r4: 6 ohms\n",
    "    \"\"\"\n",
    "    \n",
    "    # Montando a equação da LCK no Supernó:\n",
    "    # Nó 1 (v) e Nó 2 (v2 = v + v_extra)\n",
    "    # (v - v_fonte)/r1 + v/r2 + v2/r3 + v2/r4 = 0\n",
    "    # Substituindo v2:\n",
    "    # v(1/r1 + 1/r2 + 1/r3 + 1/r4) = v_fonte/r1 - v_extra/r3 - v_extra/r4\n",
    "    \n",
    "    g_total = (1/r1) + (1/r2) + (1/r3) + (1/r4)\n",
    "    i_curto = (v_fonte/r1) - (v_extra/r3) - (v_extra/r4)\n",
    "    \n",
    "    v_resultado = i_curto / g_total\n",
    "    v2 = v_resultado + v_extra\n",
    "    i_resultado = v2 / r3\n",
    "    \n",
    "    print(f\"\\n--- Resultados do Circuito ---\")\n",
    "    print(f\"Tensão v: {v_resultado:.2f} V\")\n",
    "    print(f\"Corrente i: {i_resultado:.2f} A\")\n",
    "\n",
    "# Criando a interface com sliders\n",
    "widgets.interact(\n",
    "    resolver_circuito,\n",
    "    v_fonte=widgets.FloatSlider(value=14, min=0, max=30, step=1, description='V1 (14V):'),\n",
    "    v_extra=widgets.FloatSlider(value=6, min=0, max=20, step=1, description='V2 (6V):'),\n",
    "    r1=widgets.IntSlider(value=4, min=1, max=20, description='R 4Ω:'),\n",
    "    r2=widgets.IntSlider(value=3, min=1, max=20, description='R 3Ω:'),\n",
    "    r3=widgets.IntSlider(value=2, min=1, max=20, description='R 2Ω:'),\n",
    "    r4=widgets.IntSlider(value=6, min=1, max=20, description='R 6Ω:')\n",
    ")"
   ]
  }
